# Foundry project endpoint, e.g. https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=""

# Chat model deployment used by the four reasoning agents.
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-4o"

# Per-transaction transfer limit in THB (policy SCBX-RETAIL-XFER-001). Optional.
BANK_TRANSFER_LIMIT_THB="1500"

# --- Entra ID (managed identity) ---
# User-assigned managed identity client id the hosted agent runs as. Used for
# DefaultAzureCredential(managed_identity_client_id=...) when calling Foundry.
AZURE_CLIENT_ID=""

# --- Observability / tracing (App Insights + Foundry Observability) ---
# Application Insights connection string. When set, OTel traces/metrics/logs are
# exported via Azure Monitor and surfaced in the Foundry project Observability view.
APPLICATIONINSIGHTS_CONNECTION_STRING=""
# Set to "true" to include prompt/response content in spans (sensitive data). Off by default.
OTEL_ENABLE_SENSITIVE_DATA="false"

# --- Data security policy (Purview / DSPM) ---
# Purview account that catalogs/classifies this agent's data (PII, Sensitive-PII, Account, Financial).
PURVIEW_ACCOUNT_NAME=""
# Governance / data-security policy id this agent is bound to.
GOVERNANCE_POLICY_ID="SCBX-RETAIL-XFER-001"

# --- Multi-agent registration (4 separate Foundry PromptAgents) ---
# When true (default), the four reasoning agents are published to the Foundry
# project as separate, versioned PromptAgents and the workflow connects to them.
# Set false for offline build validation (no Foundry RBAC / no network).
FOUNDRY_REGISTER_AGENTS="true"
# Optional name overrides for the four registered agents.
EKYC_AGENT_NAME="scbx-banking-ekyc"
BANK_QUERY_AGENT_NAME="scbx-banking-bank-query"
CONTROLLER_AGENT_NAME="scbx-banking-controller"
JUDGEMENT_AGENT_NAME="scbx-banking-judgement"
