# ============================================================================
# Agentic AI Platform PoC — backend configuration (.env)
# Copy to `.env` and fill in. Canonical resource names from POC_SPEC.md are
# used as the default / comment values. In MOCK_MODE=true none of the Azure
# values are required — the app serves canned responses + synthetic data.
# ============================================================================

# ---- Run mode -------------------------------------------------------------
# true  = no live Azure calls; model calls return canned responses and tokens
#         are estimated (len/4). Use for local demo / CI.
# false = wire real Azure resources (see TODOs in code).
MOCK_MODE=true
# Hybrid live: keep synthetic tools but make real model/agent calls.
#   LIVE_LLM=true            -> direct Azure OpenAI chat calls.
#   USE_FOUNDRY_AGENTS=true  -> route steps through the provisioned Foundry
#                               prompt agents (Foundry Agent Service) and export
#                               gen_ai spans to the project's App Insights.
LIVE_LLM=false
USE_FOUNDRY_AGENTS=false
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ---- Azure OpenAI (Foundry Models): agpoc-aoai-dev ------------------------
AZURE_OPENAI_ENDPOINT=https://agpoc-aoai-dev.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
# Deployment names (canonical):
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini

# ---- API Management (tool bridge): agpoc-apim-dev -------------------------
# All tool calls route through APIM, which fronts Azure Functions agpoc-func-tools-dev.
APIM_BASE_URL=https://agpoc-apim-dev.azure-api.net/tools
APIM_SUBSCRIPTION_KEY=

# ---- Azure AI Search: agpoc-search-dev ------------------------------------
AZURE_SEARCH_ENDPOINT=https://agpoc-search-dev.search.windows.net
AZURE_SEARCH_INDEX=memo-corpus

# ---- Cosmos DB (audit + state store): agpoc-cosmos-dev --------------------
COSMOS_ENDPOINT=https://agpoc-cosmos-dev.documents.azure.com:443/
COSMOS_DATABASE=agentaudit
# Containers (canonical): runs, steps, handoffs, tokens
COSMOS_CONTAINER_RUNS=runs
COSMOS_CONTAINER_STEPS=steps
COSMOS_CONTAINER_HANDOFFS=handoffs
COSMOS_CONTAINER_TOKENS=tokens

# ---- Application Insights: agpoc-appi-dev ---------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---- Service Bus (HITL): agpoc-sb-dev, queue hitl-approvals ---------------
SERVICEBUS_NAMESPACE=agpoc-sb-dev.servicebus.windows.net
SERVICEBUS_HITL_QUEUE=hitl-approvals

# ---- Microsoft Entra ID (workload identity) -------------------------------
# App registrations: agpoc-orchestrator, agpoc-tool-bridge, agpoc-ui
AZURE_TENANT_ID=
ENTRA_ORCHESTRATOR_CLIENT_ID=
ENTRA_TOOL_BRIDGE_CLIENT_ID=
ENTRA_UI_CLIENT_ID=
# When deployed to Container Apps, DefaultAzureCredential uses the managed
# identity; locally it falls back to az-cli / VS Code / env credentials.

# ---- Data paths (mock mode) -----------------------------------------------
# Relative to repo root; resolved in config.py.
DATA_DIR=../data
