{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "7852385947120541386"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Deployment region. swedencentral has gpt-4o quota; southeastasia does not."
      }
    },
    "prefix": {
      "type": "string",
      "defaultValue": "agpoc",
      "metadata": {
        "description": "Resource name prefix."
      }
    },
    "env": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Environment tag/suffix."
      }
    },
    "gpt4oVersion": {
      "type": "string",
      "defaultValue": "2024-11-20",
      "metadata": {
        "description": "gpt-4o model version."
      }
    },
    "gpt4oMiniVersion": {
      "type": "string",
      "defaultValue": "2024-07-18",
      "metadata": {
        "description": "gpt-4o-mini model version."
      }
    },
    "gpt4oCapacity": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "GlobalStandard capacity (x1000 TPM) for gpt-4o."
      }
    },
    "gpt4oMiniCapacity": {
      "type": "int",
      "defaultValue": 50,
      "metadata": {
        "description": "GlobalStandard capacity (x1000 TPM) for gpt-4o-mini."
      }
    }
  },
  "variables": {
    "tags": {
      "project": "agentic-ai-poc",
      "env": "[parameters('env')]",
      "partner": "DataX-TechX-Microsoft",
      "data": "synthetic-only"
    },
    "uniq": "[uniqueString(resourceGroup().id)]",
    "foundryName": "[format('{0}-aifoundry-{1}', parameters('prefix'), parameters('env'))]",
    "projectName": "[format('{0}-proj-{1}', parameters('prefix'), parameters('env'))]",
    "lawName": "[format('{0}-law-{1}', parameters('prefix'), parameters('env'))]",
    "appiName": "[format('{0}-appi-{1}', parameters('prefix'), parameters('env'))]",
    "cosmosName": "[format('{0}-cosmos-{1}-{2}', parameters('prefix'), parameters('env'), variables('uniq'))]",
    "kvName": "[take(format('{0}kv{1}{2}', parameters('prefix'), parameters('env'), variables('uniq')), 24)]",
    "uamiName": "[format('{0}-id-orchestrator-{1}', parameters('prefix'), parameters('env'))]",
    "auditContainers": [
      "runs",
      "steps",
      "handoffs",
      "tokens"
    ],
    "roleOpenAiUser": "a97b65f3-24c7-4388-baec-2e87135dc908",
    "roleKvSecretsUser": "4633458b-17de-408a-b874-0445c86b69e6"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('lawName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appiName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]",
        "IngestionMode": "LogAnalytics"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
      ]
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[variables('uamiName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-06-01",
      "name": "[variables('foundryName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[toLower(variables('foundryName'))]",
        "publicNetworkAccess": "Enabled",
        "disableLocalAuth": false
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', variables('foundryName'), variables('projectName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "displayName": "Agentic AI PoC",
        "description": "DataX/TechX x Microsoft — credit memo + conversational banking agents."
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects/connections",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}/{2}', variables('foundryName'), variables('projectName'), variables('appiName'))]",
      "properties": {
        "category": "AppInsights",
        "target": "[resourceId('Microsoft.Insights/components', variables('appiName'))]",
        "authType": "ApiKey",
        "isSharedToAll": true,
        "credentials": {
          "key": "[reference(resourceId('Microsoft.Insights/components', variables('appiName')), '2020-02-02').ConnectionString]"
        },
        "metadata": {
          "ApiType": "Azure",
          "ResourceId": "[resourceId('Microsoft.Insights/components', variables('appiName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appiName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/projects', variables('foundryName'), variables('projectName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', variables('foundryName'), 'gpt-4o')]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": "[parameters('gpt4oCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o",
          "version": "[parameters('gpt4oVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', variables('foundryName'), 'gpt-4o-mini')]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": "[parameters('gpt4oMiniCapacity')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o-mini",
          "version": "[parameters('gpt4oMiniVersion')]"
        },
        "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
        "raiPolicyName": "Microsoft.DefaultV2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('foundryName'), 'gpt-4o')]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-11-15",
      "name": "[variables('cosmosName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "enableAutomaticFailover": false,
        "capabilities": [
          {
            "name": "EnableServerless"
          }
        ],
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0,
            "isZoneRedundant": false
          }
        ],
        "disableLocalAuth": false
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', variables('cosmosName'), 'agentaudit')]",
      "properties": {
        "resource": {
          "id": "agentaudit"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]"
      ]
    },
    {
      "copy": {
        "name": "containers",
        "count": "[length(variables('auditContainers'))]"
      },
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosName'), 'agentaudit', variables('auditContainers')[copyIndex()])]",
      "properties": {
        "resource": {
          "id": "[variables('auditContainers')[copyIndex()]]",
          "partitionKey": {
            "paths": [
              "/run_id"
            ],
            "kind": "Hash"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosName'), 'agentaudit')]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('kvName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 7,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), variables('roleOpenAiUser'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleOpenAiUser'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), variables('roleKvSecretsUser'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleKvSecretsUser'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlRoleAssignments",
      "apiVersion": "2024-11-15",
      "name": "[format('{0}/{1}', variables('cosmosName'), guid(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '00000000-0000-0000-0000-000000000002'))]",
      "properties": {
        "roleDefinitionId": "[format('{0}/sqlRoleDefinitions/00000000-0000-0000-0000-000000000002', resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')))]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]",
        "scope": "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
      ]
    }
  ],
  "outputs": {
    "foundryAccountResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]"
    },
    "foundryAccountName": {
      "type": "string",
      "value": "[variables('foundryName')]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName')), '2025-06-01').endpoint]"
    },
    "projectName": {
      "type": "string",
      "value": "[variables('projectName')]"
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.services.ai.azure.com/api/projects/{1}', toLower(variables('foundryName')), variables('projectName'))]"
    },
    "aoaiEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.openai.azure.com/', toLower(variables('foundryName')))]"
    },
    "gpt4oDeployment": {
      "type": "string",
      "value": "gpt-4o"
    },
    "gpt4oMiniDeployment": {
      "type": "string",
      "value": "gpt-4o-mini"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2024-11-15').documentEndpoint]"
    },
    "cosmosAccountName": {
      "type": "string",
      "value": "[variables('cosmosName')]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('kvName')]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), '2023-07-01').vaultUri]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appiName')), '2020-02-02').ConnectionString]"
    },
    "logAnalyticsId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
    },
    "orchestratorIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').clientId]"
    },
    "orchestratorIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName')), '2023-01-31').principalId]"
    },
    "orchestratorIdentityResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('uamiName'))]"
    }
  }
}