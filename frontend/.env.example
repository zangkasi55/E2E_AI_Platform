# Frontend runtime config (Vite). Copy to .env.local and edit.
# Default is mock mode (no backend needed). Set to "false" to call the live
# FastAPI orchestrator (agpoc-aca-orch-dev) once it is deployed.
VITE_USE_MOCK=true

# Base URL of the FastAPI orchestrator (only used when VITE_USE_MOCK=false).
VITE_API_BASE_URL=https://agpoc-aca-orch-dev.azurecontainerapps.io

# Entra ID app registration for the UI (agpoc-ui). Used to acquire bearer
# tokens for /api/* calls in live mode.
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
